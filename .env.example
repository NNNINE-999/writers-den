# 数据库连接
# 本地开发（默认）：file:./writers-den.db
# 生产环境：libsql://[your-db].turso.io
DATABASE_URL=file:./writers-den.db
# Turso 认证令牌（仅生产环境需要）
TURSO_AUTH_TOKEN=

# QQ 邮箱 SMTP 配置
# 1. 登录 QQ 邮箱 → 设置 → 账户 → 开启 POP3/SMTP 服务
# 2. 获取授权码（不是 QQ 密码）
# 3. 填入下方
SMTP_USER=your_qq_email@qq.com
SMTP_PASS=your_smtp_authorization_code
